---js 
{ now: new Date() }
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ title }}
            | Peter Bryant</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin">
        <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.colors.min.css">
        <link rel="stylesheet" href="/bundle.css">
    </head>
    <body>
        <header>
            <nav class="container">
                <ul>
                    <li>
                        <a {% if page.url == '/' %} aria-current="page" {% endif %} class="contrast" href="/">
                            <strong>Peter Bryant</strong>
                        </a>
                    </li>
                </ul>
                <ul>
                    {%- for pg in collections.page -%}
                        <li>
                            <a {% if page.url == pg.url %} aria-current="page" {% endif %} href={{ pg.url }}>{{ pg.data.title }}</a>
                        </li>
                    {%- endfor -%}
                </ul>
            </nav>
            <hr/>
        </header>

        <main class="container">
            {{ content | safe }}
        </main>

        <hr/>

        <footer>
            <div class="container">
                <ul class="footer-links">
                    {%- for pg in collections['footer-page'] -%}
                        <li class="footer-link">
                            <a {% if page.url == pg.url %} aria-current="page" {% endif %} href={{ pg.url }}>
                                <small>{{ pg.data.title }}</small>
                            </a>
                        </li>
                    {%- endfor -%}
                </ul>

                <p>
                    <small>
                        Copyright © Peter Bryant {{ now | date("yyyy") }}
                    </small>
                </p>

            </div>
        </footer>
    </body>
</html>